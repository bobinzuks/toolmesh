{
  "mcpServers": {
    "claude-flow": {
      "command": "npx",
      "args": [
        "@claude-flow/cli@latest",
        "mcp",
        "start"
      ],
      "env": {
        "CLAUDE_FLOW_MODE": "v3",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDE_FLOW_TOPOLOGY": "hierarchical-mesh",
        "CLAUDE_FLOW_MAX_AGENTS": "15",
        "CLAUDE_FLOW_MEMORY_BACKEND": "hybrid"
      },
      "autoStart": false
    },
    "aan": {
      "command": "node",
      "args": [
        "--import",
        "tsx",
        "/run/media/bobinzuks/82ae4087-99fd-4170-b394-3f47ac90dca1/projects/projects/agent-affiliate-network/src/index.ts"
      ],
      "env": {}
    }
  }
}