{
  "name": "@aan/mcp",
  "version": "0.1.0",
  "description": "Agent Affiliate Network — AI agents recommend SaaS products, you earn commissions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aan": "dist/cli.js",
    "aan-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp src/dashboard/ui.html dist/dashboard/ui.html",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "seed": "node dist/seed.js",
    "init": "node dist/cli.js init",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "keywords": [
    "mcp",
    "affiliate",
    "agent",
    "ai",
    "recommendations",
    "a2a",
    "model-context-protocol",
    "saas"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropic/agent-affiliate-network.git"
  },
  "homepage": "https://github.com/anthropic/agent-affiliate-network#readme",
  "bugs": {
    "url": "https://github.com/anthropic/agent-affiliate-network/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "sqlite-vec": "^0.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
